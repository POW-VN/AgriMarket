# ==============================================
# AgriMarket Backend - File mau cau hinh
# Sao chep thanh .env va dien gia tri thuc
# cp .env.example .env
# ==============================================

# DATABASE (PostgreSQL)
DB_URL=jdbc:postgresql://localhost:5432/agrimarket
DB_USER=postgres
DB_PASSWORD=

# EMAIL - Brevo SMTP (dang ky tai brevo.com)
GMAIL_USERNAME=
GMAIL_PASSWORD=

# GEMINI AI (lay tai aistudio.google.com)
GEMINI_API_KEY=

# AGORA VIDEO CALL (lay tai console.agora.io)
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

# GHN SHIPPING (lay tai dev.ghn.vn)
GHN_API_TOKEN=
GHN_API_SHOPID=
GHN_API_URL=https://dev-online-gateway.ghn.vn/shiip/public-api/v2/shipping-order/create
GHN_SIMULATION_ENABLED=true

# VNPAY (localhost khi dev, domain that khi deploy)
VNP_RETURN_URL=http://localhost:3000/payment/vnpay-callback
